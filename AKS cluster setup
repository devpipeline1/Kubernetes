Install Azure CLI via git bash
winget install --exact --id Microsoft.AzureCLI

add path for git bash
echo 'export PATH=$PATH:/c/Program Files/Microsoft SDKs/Azure/CLI2/wbin' >> ~/.bashrc
source ~/.bashrc

az --version

az login

az account show
 az group create --name MyResourceGroup --location southindia

Register the Resource Provider
az provider register --namespace Microsoft.OperationalInsights

Verify the registration
az provider show --namespace Microsoft.OperationalInsights --query "registrationState"

az aks create   --resource-group MyResourceGroup   --name MyAKSCluster   --node-count 1   --enable-addons monitoring   --generate-ssh-keys

az aks create --resource-group MyResourceGroup --name MyAKSCluster1 --node-count 1 --node-vm-size Standard_E4s_v5   --enable-cluster-autoscaler --min-count 1 --max-count 2 --generate-ssh-keys


